{
  "name": "@flow-tools-dev/flow-structures",
  "version": "1.0.0",
  "description": "Chainable, immutable array and map/object utilities for TypeScript.",
  "keywords": [
    "lodash",
    "ramda",
    "highland",
    "functional programming",
    "fp",
    "chainable",
    "immutable",
    "array",
    "map",
    "object",
    "collection",
    "utilities",
    "typescript",
    "flowlist",
    "flowcollection"
  ],
  "homepage": "https://github.com/flow-tools-dev/flow-structures#readme",
  "bugs": {
    "url": "https://github.com/flow-tools-dev/flow-structures/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flow-tools-dev/flow-structures.git"
  },
  "license": "MIT",
  "author": "Adam Allison",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "test": "vitest",
    "build": "tsdown",
    "publish": "npm run test -- --run && npm run build && npm publish --access public"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "happy-dom": "^20.9.0",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
